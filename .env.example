# OpenAI API key (required).
OPENAI_API_KEY=sk-your-key-here

# OpenAI Realtime model. Default: gpt-realtime-2 (reasoning model with preamble support).
# Other options: gpt-realtime-1.5, gpt-realtime, gpt-realtime-mini.
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Default TTS voice. Recommended: marin or cedar.
# All options: alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar.
OPENAI_REALTIME_VOICE=marin

# UI language is a browser SettingsPanel preference, persisted in localStorage,
# and is not controlled by a server env var. Conversation language is also set
# in SettingsPanel as "transcription language"; it applies on the next
# connection. en/ja are fully supported, while ko/zh/es/fr/de have lightweight
# yes/no approval detection only.

# Gemini Live API キー (provider="gemini" 選択時に必要)
# GEMINI_API_KEY=your-google-ai-key

# Gemini Live のデフォルトモデル
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Server listen port for the browser to connect to. Default 8787.
SERVER_PORT=8787

# Codex working directory. Codex CLI will operate in this directory.
# Recommended: a dedicated workspace away from the agent's own source.
# If omitted, defaults to ./server/workspace/ (auto-created, gitignored).
# CODEX_CWD=/absolute/path/to/your/project

# Codex reasoning effort. "low" | "medium" | "high".
# Overrides `model_reasoning_effort` in ~/.codex/config.toml for this
# session only. "low" is significantly faster for short tasks; "high"
# gives the best results on complex coding work.
# CODEX_REASONING_EFFORT=low

# Codex turn idle timeout (ms). If no bridge event is received for this
# long during a Codex turn, the session interrupts the turn via
# bridge.interruptTurn() to recover from hung MCP tools or stalled
# subprocesses. Default 60000 (60s).
# CODEX_TURN_IDLE_TIMEOUT_MS=60000

# Realtime API のトークン単価 (USD per 1M tokens)。 SettingsPanel のコスト表示用。
# デフォルトは gpt-realtime-2 の公式値:
#   https://developers.openai.com/api/docs/pricing
# 他のモデルを使う場合は上書き:
#   gpt-realtime-mini  → input text 0.6  / audio 10 / cached 0.06,0.3 / output text 2.4 / audio 20
#   gpt-realtime-1.5   → input text 4    / audio 32 / cached 0.4,0.4  / output text 16  / audio 64
# REALTIME_RATE_INPUT_TEXT_PER_M=4
# REALTIME_RATE_INPUT_AUDIO_PER_M=32
# REALTIME_RATE_INPUT_CACHED_TEXT_PER_M=0.4
# REALTIME_RATE_INPUT_CACHED_AUDIO_PER_M=0.4
# REALTIME_RATE_OUTPUT_TEXT_PER_M=24
# REALTIME_RATE_OUTPUT_AUDIO_PER_M=64
